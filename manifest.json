      "src": "favicon.png",
      "sizes": "192x192 512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ]
}
document.getElementById('csv-file-input').addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = function(e) {
        const text = e.target.result;
        const rows = text.split('\n').filter(row => row.trim() !== '');
        const headers = rows[0].split(',').map(h => h.trim());
        
        const importedData = rows.slice(1).map(row => {
            const values = row.split(',');
            let obj = {};
            headers.forEach((h, i) => obj[h] = values[i] ? values[i].trim() : '');
            return obj;
        });

        // Merge with existing transactions
        transactions = [...transactions, ...importedData];
        localStorage.setItem('vault_transactions', JSON.stringify(transactions));
        
        alert(`Successfully imported ${importedData.length} transactions!`);
        updateDashboard();
    };
    reader.readAsText(file);
});
